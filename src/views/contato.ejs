<%- include('includes/head'); %>
<%- include('includes/nav'); %>

<div class="container">
  <div class="row">
    <div class="col-lg-2"></div>

    <div class="col-lg-8 my-4">
        <h1 class="text-center">Contato</h1>
        <p class="text-center lead">Crie seu contao abaixo</p>

        <%- include('includes/messages') %>

        <% if(user._id) { %>
        <form action="/contato/edit/<%= user._id %>" method="POST">
        <% } else { %>
        <form action="/contato/register" method="POST">
        <% } %>
          <h4>Login</h4>
          <p>Caso você já tenha uma conta, entre nela por aqui:</p>
          <div class="mb-3">
              <label>Nome</label>
              <input value ="<%= user.nome %>" type="text" class="form-control" name="nome">
          </div>
          <div class="mb-3">
              <label>Sobrenome</label>
              <input value ="<%= user.sobrenome %>" type="text" class="form-control" name="sobrenome">
          </div>
          <div class="mb-3">
              <label>Número</label>
              <input value ="<%= user.fone %>" type="text" class="form-control" name="numero">
          </div>
          <div class="mb-3">
              <label>E-mail</label>
              <input value ="<%= user.email %>" type="text" class="form-control" name="email">
          </div>
          <button type="submit" class="btn btn-primary">salvar</button>
        </form>
    
      </div>

    <div class="col-lg-2"></div>
  </div>
</div>

<%- include('includes/footer'); %> 